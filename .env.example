# Pixiv 小说阅读器 - 环境变量示例
# 复制此文件为 .env.development 或 .env.production，并根据需要修改

# ==================== 前端配置 ====================

# 代理后端地址（必须设置）
# 本地开发示例：http://127.0.0.1:8000
# 生产环境示例：https://px-reader-proxy.deno.dev
VITE_API_BASE_URL=https://px-reader-proxy.deno.dev

# ==================== 可选配置 ====================

# 应用标题
# VITE_APP_TITLE=Pixiv 小说阅读器

# 应用版本
# VITE_APP_VERSION=1.0.0
